{
    "version": "1.0",
    "description": "owen config for windows-terminal-preview. Set powershell 7 as default, remove ctrl+v keybindings.",
    "homepage": "https://github.com/owenstake/owen-bucket",
    "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
    "hash" : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
    "depends": ["windows-terminal-preview","powershell"],
    "installer": {
      "script": [
        "''",
        "# 1. Automatically locate the Windows Terminal configuration file path via Scoop                                               ",
        "$jsonDir = $(scoop prefix windows-terminal-preview) + '/settings'                                                               ",
        "$jsonPath = $jsonDir + '/settings.json'                                                                                         ",
        "if (-not (Test-Path $jsonDir)) {                                                                                               ",
        "  Write-Error 'Could not find the <settings> folder. Please make sure Windows Terminal Preview is installed via Scoop.'      ",                                         
        "  return                                                                                                                     ",
        "}                                                                                                                              ",
        "                                                                                                                               ",
        "# 3. Read the existing JSON content                                                                                            ",
        "# (Specifying UTF8 encoding to perfectly preserve Chinese characters like '命令提示符' if any)                                 ",                                                
        "if (-not (Test-Path $jsonPath)) {                                                                                              ",
        "  $jsonContent = [PSCustomObject]@{                                                                                                ",
        "      '`$schema'       = 'https://aka.ms/terminal-profiles-schema'                                                                 ",
        "      'defaultProfile' = `$null # Your pwsh 7 GUID                                                                                 ",
        "      'actions'        = @()                                                                                                       ",
        "      'profiles'       = [PSCustomObject]@{                                                                                        ",
        "          'defaults'     = [PSCustomObject]@{}                                                                                     ",
        "          'copyOnSelect' = $true                                                                                                   ",
        "          'list'         = @()                                                                                                     ",
        "      }                                                                                                                            ",
        "      'schemes'        = @()                                                                                                       ",
        "  }                                                                                                                                ",
        "} else {                                                                                                                       ",
        "  $rawContent = Get-Content $jsonPath -Raw -Encoding utf8                                                                      ",
        "  $jsonContent = ConvertFrom-Json $rawContent                                                                                  ",
        "}                                                                                                                              ",
        "                                                                                                                               ",
        "# 4. Build your new Profile object                                                                                             ",
        "$newProfile = [PSCustomObject]@{                                                                                               ",
        "    altGrAliasing     = $true                                                                                                  ",
        "    antialiasingMode  = 'grayscale'                                                                                            ",
        "    closeOnExit       = 'automatic'                                                                                            ",
        "    colorScheme       = 'Campbell'                                                                                             ",
        "    commandline       = 'pwsh.exe'                                                                                             ",
        "    cursorShape       = 'bar'                                                                                                  ",
        "    font              = [PSCustomObject]@{                                                                                     ",
        "        face = 'Cascadia Mono'                                                                                                 ",
        "        size = 12                                                                                                              ",
        "    }                                                                                                                          ",
        "    guid              = '{54434b12-7173-4ff1-8d1f-7b3bafc78b44}'                                                               ",
        "    hidden            = $false                                                                                                 ",
        "    historySize       = 9001                                                                                                   ",
        "    icon              = 'ms-appx:///ProfileIcons/{61c54bbd-c2c6-5271-96e7-009a87ff44bf}.png'                                   ",            
        "    name              = 'pwsh 7'                                                                                               ",
        "    padding           = '8, 8, 8, 8'                                                                                           ",
        "    snapOnInput       = $true                                                                                                  ",
        "    startingDirectory = '%USERPROFILE%'                                                                                        ",
        "    useAcrylic        = $false                                                                                                 ",
        "}                                                                                                                              ",
        "                                                                                                                               ",
        "# 3. Check keybindings or actions array and execute filtration deletion                                                        ",
        "if ($null -ne $jsonContent.keybindings) {                                                                                      ",
        "    # Filter out items where the keys attribute equals 'ctrl+v'                                                                ",
        "    $jsonContent.keybindings = @($jsonContent.keybindings | Where-Object { $_.keys -ne 'ctrl+v' })                             ",                  
        "    Write-Host 'Successfully removed ctrl+v from keybindings!' -ForegroundColor Green                                          ",     
        "}                                                                                                                              ",
        "                                                                                                                               ",
        "# 5. Check if the GUID already exists to avoid duplicate entries                                                               ",
        "$isExist = $jsonContent.profiles.list | Where-Object { $_.guid -eq $newProfile.guid }                                          ",     
        "                                                                                                                               ",
        "if ($isExist) {                                                                                                                ",
        "    Write-Warning 'Profile (pwsh 7) already exists in the list. No need to add it again.'                                      ",         
        "} else {                                                                                                                       ",
        "    # Precisely append the new configuration to the end of your JSON structure's profiles.list array                           ",                    
        "    $jsonContent.profiles.list += $newProfile                                                                                  ",
        "    Write-Host 'Successfully appended pwsh 7 profile item.' -ForegroundColor Green                                             ",  
        "}                                                                                                                              ",
        "                                                                                                                               ",
        "# 🌟【Core Step】Explicitly modify defaultProfile to the GUID of pwsh 7                                                        ",
        "$jsonContent.defaultProfile = '{54434b12-7173-4ff1-8d1f-7b3bafc78b44}'                                                         ",
        "",
        "if (-not (Get-Member -InputObject $jsonContent -Name 'copyOnSelect')) {                                                        ",
        "    $jsonContent | Add-Member -NotePropertyName 'copyOnSelect' -NotePropertyValue $true -Force                                 ",
        "} else {                                                                                                                       ",
        "    $jsonContent.copyOnSelect = $true                                                                                          ",
        "}                                                                                                                              ",
        "Write-Host 'Successfully set pwsh 7 as the default startup terminal!' -ForegroundColor Green                                   ",            
        "                                                                                                                               ",
        "# 6. Convert the merged object back to a standard JSON string                                                                  ",
        "# (Specify Depth 10 to ensure nested levels like 'font' do not turn into strings)                                              ",                                                             
        "$updatedJson = $jsonContent | ConvertTo-Json -Depth 10                                                                         ",
        "                                                                                                                               ",
        "# 7. Write back to the file using .NET native method to ensure proper UTF-8 with BOM encoding and prevent encoding corruption  ",                                             
        "[System.IO.File]::WriteAllText($jsonPath, $updatedJson, [System.Text.Encoding]::UTF8)                                          ",     
        "                                                                                                                               ",
        "Write-Host 'All operations saved! Restart Windows Terminal to launch straight into pwsh 7!' -ForegroundColor Cyan              ",                                 
        ""
      ]
    },
    "uninstaller": {
      "script": [
        "''",
        "# 1. Automatically locate the Windows Terminal configuration file path via Scoop                                    ",                             
        "$jsonDir = (scoop prefix windows-terminal-preview) + '/settings'                                                    ",            
        "$jsonPath = $jsonDir + '/settings.json'                                                                              ",
        "if (-not (Test-Path $jsonPath)) {                                                                                   ",
        "    Write-Error 'Could not find settings.json. Please make sure Windows Terminal Preview is installed via Scoop.'   ",                                                             
        "    return                                                                                                          ",
        "}                                                                                                                   ",
        "                                                                                                                    ",
        "# 2. Automatically create a safe backup                                                                             ",
        "$backupPath = $jsonPath + '.bak'                                                                                    ",
        "Copy-Item $jsonPath $backupPath -Force                                                                              ",
        "Write-Host 'Safe backup created at: settings.json.bak' -ForegroundColor 'Cyan'                                      ",                          
        "                                                                                                                    ",
        "# 3. Read and parse the JSON content                                                                                ",
        "$rawContent = Get-Content $jsonPath -Raw -Encoding utf8                                                             ",   
        "$jsonContent = ConvertFrom-Json $rawContent                                                                         ",
        "                                                                                                                    ",
        "# Target GUID to be removed                                                                                         ",
        "$targetGuid = '{54434b12-7173-4ff1-8d1f-7b3bafc78b44}'                                                              ",  
        "                                                                                                                    ",
        "# 4. Check if the Profile exists                                                                                    ",
        "$profileToRemove = $jsonContent.profiles.list | Where-Object { $_.guid -eq $targetGuid }                            ",                                    
        "                                                                                                                    ",
        "if (-not $profileToRemove) {                                                                                        ",
        "    Write-Warning ('Profile with GUID ' + $targetGuid + ' not found in the configuration file. No action needed.')  ",                                                            
        "} else {                                                                                                            ",
        "    # 🌟 Core Step: Filter out the target GUID to perform the removal                                               ",                 
        "    $jsonContent.profiles.list = $jsonContent.profiles.list | Where-Object { $_.guid -ne $targetGuid }              ",                                                  
        "    Write-Host 'Successfully removed the Profile from the list.' -ForegroundColor 'Green'                           ",                                     
        "                                                                                                                    ",
        "    # 5. Safely handle the default profile                                                                          ",
        "    if ($jsonContent.defaultProfile -eq $targetGuid) {                                                              ",  
        "        $jsonContent.defaultProfile = '{61c54bbd-c2c6-5271-96e7-009a87ff44bf}'                                      ",                          
        "        Write-Host 'Restored the default startup terminal to Windows PowerShell.' -ForegroundColor 'Yellow'         ",                                                       
        "    }                                                                                                               ",
        "                                                                                                                    ",
        "    # 6. Convert the merged object back to a standard JSON string                                                   ",             
        "    $updatedJson = $jsonContent | ConvertTo-Json -Depth 10                                                          ",      
        "                                                                                                                    ",
        "    # 7. Write back to the file using .NET native method                                                            ",    
        "    [System.IO.File]::WriteAllText($jsonPath, $updatedJson, [System.Text.Encoding]::UTF8)                           ",                                     
        "                                                                                                                    ",
        "    Write-Host 'Success! Changes saved safely, Windows Terminal has been restored!' -ForegroundColor 'Green'        ",                                                        
        "}                                                                                                                   ",
        ""
      ]
    }
}
