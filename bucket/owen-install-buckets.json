{
  "version": "1.0",
  "description": "Owen setup scoop buckets for all.",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash" : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "depends": ["git","7zip"],
  "buckets": { 
    "main":        "https://gitee.com/scoop-installer/main",
    "extras":      "https://gitee.com/scoop-installer/extras",
    "DEV-tools":   "https://github.com/anderlli0053/DEV-tools",
    "owen-bucket": "https://github.com/owenstake/owen-bucket",
    "versions":    "https://gitee.com/scoop-installer/versions",
    "nerd-fonts":  "https://mirror.nju.edu.cn/git/scoop-nerd-fonts.git"
  },
  "installer": {
    "script": [
      "''                                                                            ",
      "$buckets = $manifest.buckets                                                  ",
      "                                                                              ",
      "$installed = $(scoop bucket list).name                                        ",
      "$targetBuckets = $buckets.PSObject.Properties.Name                            ",
      "$toInstall = @($targetBuckets | Where-Object { $_ -notin $installed })        ",
      "If ($toInstall) {                                                             ",
      "  Write-Host '检测到以下Bucket尚未安装，开始查漏补缺：' -ForegroundColor Cyan ",
      "  Write-Host ($toInstall -join ' ') -ForegroundColor Yellow                   ",
      "  ForEach ($b in $toInstall) {                                                ",
      "    scoop bucket add $b $buckets.$b                                           ",
      "  }                                                                           ",
      "} else {                                                                      ",
      "  INFO '🎉完美！全家桶清单中的所有Bucket均已妥善安装。'                       ",
      "}                                                                             ",
      "                                                                              ",
      "# 5. 输出差异结果                                                             ",
      "Write-Host '========================================' -ForegroundColor Cyan   ",
      "$extraBuckets = @($installed | Where-Object { $_ -notin $targetBuckets })     ",
      "if ($extraBuckets) {                                                          ",
      "  WARN 🔧检测到本地已安装、但【未记入】当前全家桶清单的Bucket：               ",
      "  Write-Host ($extraBuckets -join ' ') -ForegroundColor Magenta               ",
      "  INFO 提示：你可以将以上Bucket名称追加到清单的 depends 数组中。              ",
      "} else {                                                                      ",
      "  INFO 🎉完美！本地已安装的所有Bucket均已 100% 被你的清单依赖追踪锁定。       ",
      "}                                                                             ",
      "Write-Host '========================================' -ForegroundColor Cyan   ",
      "WARN 'Please change shell to powershell 7.'                                   ",
      "scoop install powershell                                                      "
    ]
  },
  "uninstaller": { "script": [ ] }
}




