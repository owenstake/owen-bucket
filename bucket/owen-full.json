  "installer": {
    "script": [
      "# $hm = @{}                                                                                         ",
      "# ForEach($a in $manifest.depends) {                                                                ",
      "#   if ($a.contains('/')) {                                                                         ",
      "#     $c = $a.Split('/')[-1].Trim()                                                                 ",
      "#     $hm[$c] = $a                                                                                  ",
      "#   }                                                                                               ",
      "# }                                                                                                 ",
      "$targetApps = @($manifest.depends | ForEach-Object {$_.Split('/')[-1].Trim()})                      ",
      "$installed = (scoop list).name                                                                      ",
      "echo '======================'                                                                       ",
      "$toInstall = @($targetApps | Where-Object { $_ -notin $installed })                                 ",
      "$extraApps = @($installed | Where-Object { $_ -notin $targetApps })                                 ",
      "if ($toInstall) {                                                                                   ",
      "  Write-Host '检测到以下依赖尚未安装，开始查漏补缺：' -ForegroundColor Cyan                         ",
      "  Write-Host ($toInstall -join ' ') -ForegroundColor Yellow                                         ",
      "  scoop install $toInstall                                                                          ",
      "} else {                                                                                            ",
      "  Write-Host '完美！全家桶清单中的所有应用均已妥善安装。' -ForegroundColor Green                    ",
      "}                                                                                                   ",
      "# 5. 输出差异结果                                                                                   ",
      "Write-Host '========================================' -ForegroundColor Cyan                         ",
      "if ($extraApps) {                                                                                   ",
      "    Write-Host '检测到本地已安装、但【未记入】当前全家桶清单的软件：' -ForegroundColor Yellow       ",
      "    Write-Host ($extraApps -join ' ') -ForegroundColor Magenta                                      ",
      "    Write-Host '提示：你可以将以上软件名称追加到清单的 depends 数组中。' -ForegroundColor Gray      ",
      "} else {                                                                                            ",
      "    Write-Host '完美！本地已安装的所有软件均已 100% 被你的清单依赖追踪锁定。' -ForegroundColor Green",
      "}                                                                                                   ",
      "Write-Host '========================================' -ForegroundColor Cyan                         "
    ]
  },
