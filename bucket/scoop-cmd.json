{
  "version": "1.0",
  "description": "Config Explorer View",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": [],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash": "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      "''                                                         ",
      "$cmds = $manifest.psobject.Properties | Where-Object {     ",
      "  $_.Name -like 'scoop-*'                                  ",
      "}                                                          ",
      "ForEach ($cmd in $cmds.Name) {                             ",
      "  $runner_script = \"$env:scoop/shims/$cmd\"               ",
      "  $content = $manifest.\"$cmd\" -join \"`r`n\"             ",
      "  INFO \"Write to $runner_script\"                         ",
      "  [System.IO.File]::WriteAllText($runner_script, $content) ",
      "}                                                          "
    ]
  },
  "uninstaller": {
    "script": [
      "''                                                         ",
      "$cmds = $manifest.psobject.Properties | Where-Object {     ",
      "  $_.Name -like 'scoop-*'                                  ",
      "}                                                          ",
      "ForEach ($cmd in $cmds.Name) {                             ",
      "  $runner_script = \"$env:scoop/shims/$cmd\"               ",
      "  $content = $manifest.\"$cmd\" -join \"`r`n\"             ",
      "  rm \"$runner_script\"                                    ",
      "  INFO \"Remove $runner_script\"                           ",
      "}                                                          "
    ]
  },
  "scoop-cd.ps1": [
    "$env:scoop = Split-Path (Split-Path (Get-Command scoop.ps1).Source -Parent) -Parent ",
    "$appsDir = Join-Path $env:scoop 'apps'                                              ",
    "$app = $args[0]                                                                     ",
    "if ([string]::isnullorEmpty($app)) {                                                ",
    "  cd $env:scoop                                                                     ",
    "} else {                                                                            ",
    "  $scoopAppDir = $(scoop prefix $app)                                               ",
    "  cd $scoopAppDir                                                                   ",
    "}                                                                                   "
  ],
  "scoop-reinstall.ps1": [
    "# Summary: Safely uninstalls and reinstalls applications                          ",
    "$env:scoop = Split-Path (Split-Path (Get-Command scoop.ps1).Source -Parent) -Parent ",
    "$appsDir = Join-Path $env:scoop 'apps'                                              ",
    "                                                                                  ",
    "ForEach ($app in $args) {                                                         ",
    "  Write-Host \"--- Processing $app ---\" -ForegroundColor Cyan                    ",
    "                                                                                  ",
    "  if (Test-Path \"$appsDir/$app/current\") {                                      ",
    "      scoop uninstall $app                                                        ",
    "  } else {                                                                        ",
    "      WARN \"$app is not installed. Skipping uninstall.\" -ForegroundColor Yellow ",
    "  }                                                                               ",
    "                                                                                  ",
    "  scoop install $app                                                              ",
    "}                                                                                 "
  ]
}
