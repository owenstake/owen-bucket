{
  "version": "1.0",
  "description": "Config Explorer View",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": [],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash": "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      '""                                                          ',
      '$runner_script = "$env:scoop/shims/scoop-reinstall.ps1"     ',
      '$content = $manifest."scoop-reinstall.ps1" -join "`r`n"     ',
      'INFO "Write to $runner_script"                              ',
      '[System.IO.File]::WriteAllText($runner_script, $content)    ',
    ]
  },
  "uninstaller": {
    "script": [
      '""                                                          ',
      'rm "$env:scoop/shims/scoop-reinstall.ps1"                   ',
      'INFO "Remove $env:scoop/shims/scoop-reinstall.ps1"          ',
    ]
  },
  "scoop-reinstall.ps1": [
    '# Summary: Safely uninstalls and reinstalls applications                               ',
    '$scoopRoot = if ($env:SCOOP) { $env:SCOOP } else { "$env:USERPROFILE/scoop" }          ',
    '$appsDir = "$scoopRoot/apps"                                                           ',
    '                                                                                       ',
    'ForEach ($app in $args) {                                                              ',
    '    Write-Host "--- Processing $app ---" -ForegroundColor Cyan                         ',
    '                                                                                       ',
    '    if (Test-Path "$appsDir/$app/current") {                                           ',
    '        scoop uninstall $app                                                           ',
    '    } else {                                                                           ',
    '        Write-Host "$app is not installed. Skipping uninstall." -ForegroundColor Yellow',
    '    }                                                                                  ',
    '                                                                                       ',
    '    scoop install $app                                                                 ',
    '}                                                                                      '
  ],
}
