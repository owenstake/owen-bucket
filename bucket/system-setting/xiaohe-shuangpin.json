{
  "version": "1.0",
  "description": "Set xiaohe shuangpin for microsoft pinyin",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash" : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      "$path = 'HKCU:/SOFTWARE/Microsoft/InputMethod/Settings/CHS'",
      "if (!(Test-Path $path)) { New-Item $path -Force | Out-Null }",
      "Set-ItemProperty -Path $path -Name 'Default Mode' -Value 1 -Type DWord",
      "Set-ItemProperty -Path $path -Name 'Enable Double Pinyin' -Value 1 -Type DWord",
      "Set-ItemProperty -Path $path -Name 'DoublePinyinScheme' -Value 10 -Type DWord",
      "Set-ItemProperty -Path $path -Name 'UserDefinedDoublePinyinScheme0' -Value '小鹤双拼*2*^*iuvdjhcwfg^xmlnpbksqszxkrltvyovt' -Type String"
    ],
  },
  "uninstaller": {
    "script": [
      "$path = 'HKCU:/SOFTWARE/Microsoft/InputMethod/Settings/CHS'",
      "if (!(Test-Path $path)) { New-Item $path -Force | Out-Null }",
      "Set-ItemProperty -Path $path -Name 'Enable Double Pinyin' -Value 0 -Type DWord"
    ]
  }
}
