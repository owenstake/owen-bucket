{
  "version": "1.0",
  "description": "Config file assocation with scoop apps",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": [
    "draw.io",
    "vim-tux",
    "typora-1.9.5",
    "7zip",
    "autohotkey1.1",
    "foxit-pdf-reader-2023"
  ],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash": "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      "",
      "# . $bucketsdir/$bucket/script/lib-file-association.ps1                   ",
      "Invoke-Expression ($manifest.common_script -join [Environment]::NewLine)  ",
      "Associate-ScoopAppWithExtension '.ahk' 'autohotkey1.1'                      ",
      "Associate-ScoopAppWithExtension '.md' 'typora-1.9.5'                        ",
      "Associate-ScoopAppWithExtension '.pdf' 'foxit-pdf-reader-2023'              ",
      "Associate-ScoopAppWithExtension '.drawio,.png,.svg' 'draw.io'               ",
      "Associate-ScoopAppWithExtension '.mp4,mkv' 'vlc'                            ",
      "$7zFileType = '.7z,.rar,.zip,.tgz,.gz,.xz'                                  ",
      "Associate-ScoopAppWithExtension $7zFileType '7zip'                          ",
    ]
  },
  "uninstaller": {
    "script": [
      '$bucket = (Get-Content $dir/install.json | ConvertFrom-Json).bucket      ',
      '# . $bucketsdir/$bucket/script/lib-file-association.ps1                  ',
      'Invoke-Expression ($manifest.common_script -join [Environment]::NewLine) ',
      'Remove-FileAssociation                                                   '
    ]
  },
  "common_script" : [
    'Function GetExeForScoop($app) {                                                                     ',
    '  $m = $(scoop cat $app | ConvertFrom-Json)                                                         ',
    '  if ($m."architecture"."64bit"."bin") {                                                            ',
    '    $exe = $m."architecture"."64bit"."bin"                                                          ',
    '  } elseif ($m."bin") {                                                                             ',
    '    $exe = $m."bin"                                                                                 ',
    '  } elseif ($m."shortcuts") {                                                                       ',
    '    $exe = $m."shortcuts"                                                                           ',
    '  } else {                                                                                          ',
    '    Write-Output ("No found exe for $app")                                                          ',
    '      return $null                                                                                  ',
    '  }                                                                                                 ',
    '  return $exe                                                                                       ',
    '}                                                                                                   ',
    '                                                                                                    ',
    'Function Touch-ProgIdWtihExtention($regName, $exe, $extension) {                                    ',
    '  $prefix = "HKCU:/Software/Classes/$regName"                                                       ',
    '  $cmdPath = "$prefix/shell/open/command"                                                           ',
    '  if (!(Test-Path $cmdPath)) { New-Item $cmdPath -Force | Out-Null }                                ',
    '  $cleanExe = $exe.Trim("`"")                                                                       ',
    '  Set-ItemProperty -Path $cmdPath -Name "(Default)" -Value ("`"$cleanExe`" `"%1`"")                 ',
    '  $extPath = "$prefix/extensions/$extension"                                                        ',
    '  if (!(Test-Path $extPath)) { New-Item $extPath -Force | Out-Null }                                ',
    '  Set-ItemProperty -Path $extPath -Name "(Default)" -Value "" -Type String                          ',
    '}                                                                                                   ',
    '                                                                                                    ',
    'Function Associate-ScoopAppWithExtension($extensions, $scoopAppName, $exeName=$null) {              ',
    '  Foreach ($e in $($extensions -split ",")) {                                                       ',
    '    $regName = "scoop.$scoopAppName"                                                                ',
    '    if (!($exeName)) { $exeName = $(GetExeForScoop $scoopAppName) }                                 ',
    '    $prefixPath = $(scoop prefix $scoopAppName)                                                     ',
    '    Touch-ProgIdWtihExtention $regName ($prefixPath + "/" + $exeName) $e                            ',
    '    $openWithPath = "HKCU:/Software/Classes/$e/OpenWithProgids"                                     ',
    '    if (!(Test-Path $openWithPath)) { New-Item $openWithPath -Force | Out-Null }                    ',
    '    Set-ItemProperty -Path $openWithPath -Name $regName -Value "" -Type String                      ',
    '  }                                                                                                 ',
    '}                                                                                                   ',
    '                                                                                                    ',
    'Function Remove-FileAssociation() {                                                                 ',
    '  if (Test-Path "HKCU:/Software/Classes") {                                                         ',
    '    $regNames = Get-ChildItem -Path "HKCU:/Software/Classes" -ErrorAction SilentlyContinue |        ',
    '      Where-Object { $_.PSChildName -like "scoop.*" } |                                             ',
    '      ForEach-Object { $_.PSChildName }                                                             ',
    '                                                                                                    ',
    '    Foreach ($r in $regNames) {                                                                     ',
    '      $extPath = "HKCU:/Software/Classes/$r/extensions"                                             ',
    '      if (Test-Path $extPath) {                                                                     ',
    '        $extensions = Get-ChildItem -Path $extPath | ForEach-Object { $_.PSChildName }              ',
    '        Foreach ($e in $extensions) {                                                               ',
    '          $progIdPath = "HKCU:/Software/Classes/$e/OpenWithProgids"                                 ',
    '            if (Test-Path $progIdPath) {                                                            ',
    '              Remove-ItemProperty -Path $progIdPath -Name $r -ErrorAction SilentlyContinue          ',
    '            }                                                                                       ',
    '        }                                                                                           ',
    '      }                                                                                             ',
    '      Remove-Item -Path ("HKCU:/Software/Classes/$r") -Recurse -Force -ErrorAction SilentlyContinue ',
    '    }                                                                                               ',
    '  }                                                                                                 ',
    '}                                                                                                   ',
  ],
}
