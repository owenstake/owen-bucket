{
  "version"    : "1.0",
  "description": "Show classic right click menu in win11",
  "homepage"   : "https://github.com/owenstake/owen-bucket",
  "depends"    : [],
  "url"        : "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash"       : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      "''                                                                                                     ",
      "'== Right click manu expansion ========='                                                              ",
      "$path = 'HKCU:/Software/Classes/CLSID/{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}/InprocServer32'           ",
      "New-Item -Path $path -Force | Out-Null                                                                 ",
      "Set-ItemProperty -Path $path -Name '(Default)' -Value ''                                               ",
      "Write-Host 'Manually Restart Explorer with < Stop-Process -Name explorer; Start-Process explorer.exe >'",
      "                                                                                                       "
    ]
  },
  "uninstaller": {
    "script": [
      "''                                                                                                     ",
      "'== Restore right click manu expansion ========='                                                      ",
      "$path = 'HKCU:/Software/Classes/CLSID/{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}/InprocServer32'           ",
      "Remove-Item -Path $path -Force -ErrorAction SilentlyContinue                                           ",
      "Write-Host 'Manually Restart Explorer with < Stop-Process -Name explorer; Start-Process explorer.exe >'",
      "                                                                                                       "
    ]
  }
}
