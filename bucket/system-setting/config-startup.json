{
  "version": "1.0",
  "description": "Config Explorer View",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": [
    "xdg",
    "wxwork",
    "wechat",
    "v2rayN-SelfContained",
    "qq",
    "weiyunsync"
  ],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash": "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      'Invoke-Expression ($manifest.common_script -join [Environment]::NewLine)           ',
      'Invoke-Expression ($manifest.register_startup_hook -join [Environment]::NewLine)   ',
      '$apps = $manifest.depends                                                      ',
      'ForEach ($a in $apps) {                                                            ',
      '  Add-StartupForScoopApp($a)                                                       ',
      '}                                                                                  ',
    ]
  },
  "uninstaller": {
    "script": [
      'Invoke-Expression ($manifest.common_script -join [Environment]::NewLine)           ',
      'Remove-AllStartupForScoopApp                                                       ',
      'Invoke-Expression ($manifest.unregister_startup_hook -join [Environment]::NewLine) ',
    ]
  },
  "common_script" : [
    '$base_config_dir = if ($env:XDG_CONFIG_HOME) { $env:XDG_CONFIG_HOME } else { $env:APPDATA }   ',
    '$xdg_start_dir = [System.IO.Path]::GetFullPath("$base_config_dir/autostart")                  ',
    '$scoopLnkDir = [Environment]::GetFolderPath('Programs') + "/Scoop Apps"                       ',
    'Function Add-StartupForScoopApp($app) {                                                       ',
    '  # $app = "wechat"                                                                           ',
    '  # Low cost invasion for host os. we are Parasitic system                                    ',
    '  $j = $(scoop cat $app | ConvertFrom-Json )                                                  ',
    '  if (!($j)) {                                                                                ',
    '    Write-Host "Skip it! manifest is null in $app. "                                          ',
    '    return                                                                                    ',
    '  }                                                                                           ',
    '  if (!($j.shortcuts)) {                                                                      ',
    '    Write-Host "Skip it! shortcuts is null in $app. "                                         ',
    '    return                                                                                    ',
    '  }                                                                                           ',
    '  if (!($j.shortcuts[0][1])) {                                                                ',
    '    Write-Host "Skip it! shortcuts[0][1] is null in $app. "                                   ',
    '    return                                                                                    ',
    '  }                                                                                           ',
    '  $lnkFile = $scoopLnkDir + "/" + "$($j.shortcuts[0][1]).lnk"                                 ',
    '  if (!(Test-Path $lnkFile))  {                                                               ',
    '    Write-Error "No Exists for $lnkFile"                                                      ',
    '    return -1                                                                                 ',
    '  }                                                                                           ',
    '  cp $lnkFile $xdg_start_dir/ -Force                                                          ',
    'return                                                                                        ',
    '}                                                                                             ',
    '                                                                                              ',
    'Function Remove-StartupForScoopApp($app) {                                                    ',
    '  Low cost invasion for host os. we are Parasitic system                                      ',
    '  $j = $(scoop cat $app | ConvertFrom-Json )                                                  ',
    '  $lnkFile = $xdg_start_dir + "/" + "$($j.shortcuts[0][1]).lnk"                               ',
    '  if (!(Test-Path $lnkFile))  {                                                               ',
    '    Write-Error "No Exists for $lnkFile"                                                      ',
    '    return -1                                                                                 ',
    '  }                                                                                           ',
    '}                                                                                             ',
    'Function Remove-AllStartupForScoopApp($app) {                                                 ',
    '  if ($xdg_start_dir) { Remove-Item -Path "$xdg_start_dir/*" -Force -Recurse }                ',
    '}                                                                                             ',
  ],
  "register_startup_hook": [
    '# 1. 動態獲取 XDG_CONFIG_HOME，若未定義則自動 Fallback 回退至 APPDATA 漫遊目錄                ',
    '$base_config_dir = if ($env:XDG_CONFIG_HOME) { $env:XDG_CONFIG_HOME } else { $env:APPDATA }   ',
    '$xdg_start_dir = [System.IO.Path]::GetFullPath("$base_config_dir/autostart")                  ',
    '                                                                                              ',
    'if (!(Test-Path $xdg_start_dir)) {                                                            ',
    '  New-Item -Path $xdg_start_dir -ItemType Directory -Force | Out-Null                         ',
    '}                                                                                             ',
    '$startup_folder = [Environment]::GetFolderPath("Startup")                                     ',
    '$runner_script = "$startup_folder/run_xdg_autostart.cmd"                                      ',
    '                                                                                              ',
    '# 2. 完美融合：內部 PowerShell 會在開機時動態去讀取系統當時的 $env:XDG_CONFIG_HOME            ',
    '$cmd_content = $manifest."run_xdg_autostart.cmd" -join "`r`n"                                     ',
    '                                                                                              ',
    '# 3. 寫入引導腳本                                                                             ',
    '[System.IO.File]::WriteAllText($runner_script, $cmd_content, [System.Text.Encoding]::Default) ',
    'Write-Host "[成功] 混合體 XDG 啟動監聽器已註冊至 Windows Startup。" -ForegroundColor Green    '
  ],
  "unregister_startup_hook": [
    '$startup_folder = [Environment]::GetFolderPath("Startup")           ',
    '$runner_script = "$startup_folder/run_xdg_autostart.cmd"            ',
    'if (Test-Path $runner_script) { Remove-Item $runner_script -Force } '
  ],
  "run_xdg_autostart.cmd" : [
    '<# : batch portion                                                                            ',
    '@echo off                                                                                     ',
    'powershell -NoProfile -ExecutionPolicy Bypass "iex (`${%~f0} | Out-String)"                   ',
    'exit /b %errorlevel%                                                                          ',
    ': end batch / begin PowerShell #>                                                             ',
    '                                                                                              ',
    '# --- 這裡開始是純 PowerShell 代碼，開機時動態計算最新的 XDG 路徑 ---                         ',
    '`$base_dir = if (`$env:XDG_CONFIG_HOME) { `$env:XDG_CONFIG_HOME } else { `$env:APPDATA }      ',
    '`$xdg_start_dir = "`$base_dir/autostart"                                                      ',
    'if (Test-Path `$xdg_start_dir) {                                                              ',
    '  Get-ChildItem `$xdg_start_dir -File | ForEach-Object {                                      ',
    '    try {                                                                                     ',
    '      # 使用 explorer 安全盲跑所有檔案                                                        ',
    '      & explorer.exe `$_.FullName                                                             ',
    '      "explorer.exe " + `$_.FullName                                                          ',
    '    } catch {}                                                                                ',
    '  }                                                                                           ',
    '}                                                                                             ',
    'sleep 10                                                                                      ',
  ],
}
