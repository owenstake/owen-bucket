{
  "version": "1.0",
  "description": "Set xiaohe shuangpin for microsoft pinyin",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": ["gsudo"],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash" : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      ". $bucketsdir/$bucket/script/lib.ps1",
      "''                                        ",
      "'===== Explorer View ==============='     ",
      "Set-HideFileExt 0   # show file extension ",
      "Set-LaunchTo    1   # launch to this pc   ",
      "                                          ",
      "'== Show fullpath in explorer top =='     ",
      "Set-ItemProperty -Path HKCU:SOFTWARE/Microsoft/Windows/CurrentVersion/Explorer/CabinetState `",
      "                -Name  FullPath           `",
      "                -Value 1",
      "",
      "Stop-Process -Name explorer; Start-Process explorer.exe    # restart explorer",

      "'============================================'       ",
      "'==== Administator Setting =================='       ",
      "'============================================'       ",
      "gsudo {                                              ",
      "    'Realtime Protection except powershell scripts'  ",
      "    Add-MpPreference -ExclusionExtension ps1         ",
      "}                                                    ",
      ""
    ]
  },
  "uninstaller": {
    "script": [
      "$bucket = (Get-Content $dir/install.json | ConvertFrom-Json).bucket",
      ". $bucketsdir/$bucket/script/lib.ps1",
      "''                                          ",
      "'===== Restore Explorer View ==============='       ",
      "Set-HideFileExt 1   # show file extension   ",
      "Set-LaunchTo    0   # launch to this pc     ",
      "                                            ",
      "'== Restore Show fullpath in explorer top =='        ",
      "Set-ItemProperty -Path HKCU:SOFTWARE/Microsoft/Windows/CurrentVersion/Explorer/CabinetState `",
      "                -Name  FullPath            `",
      "                -Value 0                    ",
      "                                            ",
      "'== Restore Set item view in navigation panel =='          ",
      "Set-ItemViewStatusInNavigationPanel 'Downloads'  1 ",
      "Set-ItemViewStatusInNavigationPanel 'Desktop'    1 ",
      "Set-ItemViewStatusInNavigationPanel 'Videos'     1 ",
      "Set-ItemViewStatusInNavigationPanel 'Musics'     1 ",
      "Set-ItemViewStatusInNavigationPanel 'Pictures'   1 ",
      "Set-ItemViewStatusInNavigationPanel '3D Objects' 1 ",
      "Set-ItemViewStatusInNavigationPanel 'Documents'  1 ",
      "Set-ItemViewStatusInNavigationPanel 'OneDrive'   1 ",
      "",
      "'== Restore right click manu expansion ========='        ",
      "$path = 'HKCU:/Software/Classes/CLSID/{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}/InprocServer32'",
      "Remove-Item -Path $path -Force -ErrorAction SilentlyContinue",
      "Stop-Process -Name explorer; Start-Process explorer.exe    # restart explorer",
      ""
    ]
  }
}
