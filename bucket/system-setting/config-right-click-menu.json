{
  "version": "1.0",
  "description": "config right click menu with scoop apps",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "depends": [
    "draw.io",
    "vim-tux",
    "typora-1.9.5",
    "7zip",
    "autohotkey1.1",
    "foxit-pdf-reader-2023"
  ],
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash": "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "installer": {
    "script": [
      '',
      'Invoke-Expression ($manifest.common_script -join [Environment]::NewLine)  ',
      '"##############################################"                          ',
      '"##### Right Click Context Menu ###############"                          ',
      '"##############################################"                          ',
      '# Set right click menu                                                    ',
      'Add-RightClickScoopItemForAll "vscode"                                    ',
      'Add-RightClickScoopItemForAll "vim-tux"                                   ',
      'Add-RightClickScoopItemForAll "7zip"                                      ',

      '# powershell.exe is better for debug than cmd.exe                         ',

      '$drawioExe = "$(scoop prefix draw.io)/$(GetExeForScoop draw.io)"    ',
      'Add-RightClickItemWithCommand ".svg,.png"                          `',
      '                              "Edit-By-Drawio"                     `',
      '                              "$drawioExe"                         `',
      '                              "$drawioExe"   "%1"                   ',
      'Add-RightClickItemWithCommand "Directory/Background"               `',
      '                              "粘贴快捷方式(环境变量)"             `',
      '                              ""                                   `',
      '                              "powershell -c `"Paste-FileAsShortcut `"%W`"``"',

      '$7zIcon = "$(scoop prefix 7zip)/7zG.exe"                                                         ',
      'Add-RightClickItemWithCommand   "AllFileSystemObjects"                                            `',
      '                                "Zip"                                                             `',
      '                                "$7zIcon"                                                       `',
      '                                "cmd /c singleinstance.exe `"%1`" powershell -c Compress-Interactive `$files --si-timeout 400"',

      'Add-RightClickItemWithCommand   "$7zFileType"           `',
      '                                "Expand"                  `',
      '                                "$7zIcon"               `',
      '                                "powershell -c `"Expand-by-7zip `"%1`" `"%W`"`" "',

      '$FoxitExe = "$(scoop prefix foxit-pdf-reader-2023)/FoxitPDFReader.exe" ',
      'Add-RightClickItemWithCommand    ".pdf"                   `',
      '                                 "Open-By-Foxit"          `',
      '                                 "$FoxitExe"              `',
      '                                 "$FoxitExe `"%1`" "       ',

      '$XmindExe = "$(scoop prefix xmind)/xmind.exe" ',
      'Add-RightClickItemWithCommand    ".xmind"                 `',
      '                                 "Open-By-Xmind"          `',
      '                                 "$XmindExe"              `',
      '                                 "$XmindExe `"%1`" "       ',

      '"Add new file item"                                                                         ',
      '$drawioFile    = (Get-ChildItem $Env:OwenInstallDir -Recurse "blank.drawio"    )[0].FullName',
      '$drawioPngFile = (Get-ChildItem $Env:OwenInstallDir -Recurse "blank.drawio.png")[0].FullName',
      '$drawioSvgFile = (Get-ChildItem $Env:OwenInstallDir -Recurse "blank.drawio.svg")[0].FullName',
      'Add-ShellNewWithTemplate $drawioPngFile                                                     ',
      'Add-ShellNewWithTemplate $drawioSvgFile                                                     ',
      '# Add-ShellNewWithTemplate  ".drawio"  $drawioFile                                          ',
      '                                                                                            '
    ]
  },
  "uninstaller": {
    "script": [
      'Invoke-Expression ($manifest.common_script -join [Environment]::NewLine) ',
      'Remove-RightClickMenu                                                    '
    ]
  },
  "common_script" : [
    'Function GetExeForScoop($app) {                                                                                              ',
    '  $m = $(scoop cat $app | ConvertFrom-Json)                                                                                  ',
    '  if ($m."architecture"."64bit"."bin") {                                                                                     ',
    '    $exe = $m."architecture"."64bit"."bin"[0]                                                                                   ',
    '#   } elseif ($m."bin") {                                                                                                      ',
    '#     $exe = $m."bin"[0]                                                                                                          ',
    '  } elseif ($m."shortcuts") {                                                                                                ',
    '    $exe = $m."shortcuts"[0][0]                                                                                                    ',
    '  } else {                                                                                                                   ',
    '    Write-Output ("No found exe for $app")                                                                                   ',
    '      return $null                                                                                                           ',
    '  }                                                                                                                          ',
    '  return $exe                                                                                                                ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Add-RightClickItemWithCommand($node="AllFileSystemObjects", $itemName, $icon="", $cmd) {                            ',
    '  $scoopItemName = "scoop-$itemName"                                                                                         ',
    '  $MuiVerb = $itemName                                                                                                       ',
    '  $extList = @()                                                                                                             ',
    '  $prefix = "HKCU:/Software/Classes"                                                                                         ',
    '  $isSet = $false                                                                                                            ',
    '  $apply = ""                                                                                                                ',
    '                                                                                                                             ',
    '  Foreach ($n in $($node -split ",")) {                                                                                      ',
    '    if ($n.StartsWith(".")) {                                                                                                ',
    '      $extList += $n.Substring(1)                                                                                            ',
    '      $n = "AllFileSystemObjects"                                                                                            ',
    '      if ($isSet) {                                                                                                          ',
    '        continue                                                                                                             ',
    '      } else {                                                                                                               ',
    '        $isSet = $true                                                                                                       ',
    '      }                                                                                                                      ',
    '    }                                                                                                                        ',
    '                                                                                                                             ',
    '    $targetPath = "$prefix/$n/shell/$scoopItemName"                                                                          ',
    '    if (!(Test-Path $targetPath)) { New-Item $targetPath -Force | Out-Null }                                                 ',
    '                                                                                                                             ',
    '    $cleanIcon = $icon.Trim("`"")                                                                                            ',
    '    Set-ItemProperty -Path $targetPath -Name "icon" -Value ("`"$cleanIcon`"" ) -Type String                                  ',
    '    Set-ItemProperty -Path $targetPath -Name "MuiVerb" -Value $MuiVerb -Type String                                          ',
    '                                                                                                                             ',
    '    $cmdPath = "$targetPath/command"                                                                                         ',
    '    if (!(Test-Path $cmdPath)) { New-Item $cmdPath -Force | Out-Null }                                                       ',
    '    Set-ItemProperty -Path $cmdPath -Name "(Default)" -Value $cmd -Type String                                               ',
    '  }                                                                                                                          ',
    '                                                                                                                             ',
    '  if ($extList.Count) {                                                                                                      ',
    '    $exts = $extList -Join " OR "                                                                                            ',
    '    $apply = "System.FileExtension: ($exts)"                                                                                 ',
    '    Set-ItemProperty -Path "$prefix/AllFileSystemObjects/shell/$scoopItemName" -Name "AppliesTo" -Value $apply -Type String  ',
    '  }                                                                                                                          ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Add-RightClickItem($extension, $itemName, $exe, $param="%1") {                                                      ',
    '  $prefix = "HKCU:/Software/Classes/$extension/Shell/scoop-tools"                                                            ',
    '  if (!(Test-Path $prefix)) { New-Item $prefix -Force | Out-Null }                                                           ',
    '  Set-ItemProperty -Path $prefix -Name "SubCommands" -Value "" -Type String                                                  ',
    '                                                                                                                             ',
    '  $itemPath = "$prefix/shell/$itemName"                                                                                      ',
    '  if (!(Test-Path $itemPath)) { New-Item $itemPath -Force | Out-Null }                                                       ',
    '  Set-ItemProperty -Path $itemPath -Name "icon" -Value ("`"$exe`"") -Type String                                             ',
    '                                                                                                                             ',
    '  $cmdPath = "$itemPath/command"                                                                                             ',
    '  if (!(Test-Path $cmdPath)) { New-Item $cmdPath -Force | Out-Null }                                                         ',
    '  Set-ItemProperty -Path $cmdPath -Name "(Default)" -Value ("`"$exe`" `"$param`"") -Type String                              ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Add-RightClickScoopItem($extension, $scoopAppName, $exeName, $param="%1") {                                         ',
    '  $itemName = "Open with & $scoopAppName"                                                                                    ',
    '  Add-RightClickItem $extension $itemName "$(scoop prefix $scoopAppName)/$exeName" $param                                                      ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Add-RightClickScoopItemForAll($scoopAppName, $param="%1") {                                                         ',
    '  $exeName = $(GetExeForScoop $scoopAppName)                                                                                 ',
    '  if ($exeName) {                                                                                                            ',
    '    Add-RightClickScoopItem "AllFileSystemObjects" $scoopAppName $exeName "%1"                                               ',
    '    Add-RightClickScoopItem "Directory/Background" $scoopAppName $exeName "%V"                                               ',
    '  }                                                                                                                          ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Add-ShellNewWithTemplate($filePath) {                                                                               ',
    '  if (!(Test-Path $filePath)) {                                                                                              ',
    '    Write-Error ("File not found! $filePath")                                                                                ',
    '      return                                                                                                                 ',
    '  }                                                                                                                          ',
    '  $extension = (Get-Item $filePath).Extension                                                                                ',
    '  $targetPath = "HKCU:/Software/Classes/$extension/ShellNew"                                                                 ',
    '  if (!(Test-Path $targetPath)) { New-Item $targetPath -Force | Out-Null }                                                   ',
    '                                                                                                                             ',
    '  Set-ItemProperty -Path $targetPath -Name "FileName" -Value $filePath -Type String                                          ',
    '}                                                                                                                            ',
    '                                                                                                                             ',
    'Function Remove-RightClickMenu() {                                                                                           ',
    '  if (Test-Path "HKCU:/Software/Classes/AllFileSystemObjects/Shell") {                                                       ',
    '    Get-ChildItem -Path "HKCU:/Software/Classes/AllFileSystemObjects/Shell" -ErrorAction SilentlyContinue |                  ',
    '      Where-Object { $_.PSChildName -like "scoop*" } |                                                                       ',
    '      ForEach-Object { Remove-Item -Path $_.PSPath -Recurse -Force -ErrorAction SilentlyContinue }                           ',
    '  }                                                                                                                          ',
    '                                                                                                                             ',
    '  if (Test-Path "HKCU:/Software/Classes/Directory/Shell") {                                                                  ',
    '    Get-ChildItem -Path "HKCU:/Software/Classes/Directory/Shell" -ErrorAction SilentlyContinue |                             ',
    '      Where-Object { $_.PSChildName -like "scoop*" } |                                                                       ',
    '      ForEach-Object { Remove-Item -Path $_.PSPath -Recurse -Force -ErrorAction SilentlyContinue }                           ',
    '  }                                                                                                                          ',
    '                                                                                                                             ',
    '  if (Test-Path "HKCU:/Software/Classes/Directory/Background/Shell") {                                                       ',
    '    Get-ChildItem -Path "HKCU:/Software/Classes/Directory/Background/Shell" -ErrorAction SilentlyContinue |                  ',
    '      Where-Object { $_.PSChildName -like "scoop*" } |                                                                       ',
    '      ForEach-Object { Remove-Item -Path $_.PSPath -Recurse -Force -ErrorAction SilentlyContinue }                           ',
    '  }                                                                                                                          ',
    '}                                                                                                                            ',

  ]
}
