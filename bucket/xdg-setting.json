{
  "version": "1.0.0",
  "description": "XDG config with scoop",
  "homepage": "https://github.com/owenstake/owen-bucket",
  "license": "Apache-2.0",
  "url": "https://github.com/owenstake/owen-bucket/releases/download/v1.0.0/Empty.txt",
  "hash" : "2E1CFA82B035C26CBBBDAE632CEA070514EB8B773F616AAEAF668E2F0BE8F10D",
  "persist": [
    "xdg-config-home", 
    "xdg-data-home", 
    "xdg-state-home", 
    "xdg-cache-home",
    "xdg-runtime-home"
  ],
  "post_install": [
      "'Setting XDG Environment Var...'",
      "[System.Environment]::SetEnvironmentVariable('XDG_CONFIG_HOME', \"$persist_dir\\xdg-config-home\", 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_DATA_HOME',   \"$persist_dir\\xdg-data-home\", 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_STATE_HOME',  \"$persist_dir\\xdg-state-home\", 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_CACHE_HOME',  \"$persist_dir\\xdg-cache-home\", 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_RUNTIME_DIR', \"$persist_dir\\xdg-runtime-home\", 'User')"
],
  "uninstaller": {
    "script": [
      "'Unsetting XDG Environment Var...'",
      "[System.Environment]::SetEnvironmentVariable('XDG_CONFIG_HOME', $null, 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_DATA_HOME',   $null, 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_STATE_HOME',  $null, 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_CACHE_HOME',  $null, 'User')",
      "[System.Environment]::SetEnvironmentVariable('XDG_RUNTIME_DIR', $null, 'User')"
    ]
  },
}
